# Backend Environment Variables
# Copy this file to .env and fill in values

# Server
PORT=5000
NODE_ENV=development

# CORS - comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# Downloads directory (default: ./downloads)
DOWNLOADS_DIR=./downloads

# File auto-delete after N minutes (default: 60)
FILE_TTL_MINUTES=60

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
CONVERT_RATE_LIMIT_MAX=10

# yt-dlp binary path (leave blank to auto-download)
YTDLP_BINARY_PATH=

# ffmpeg binary path (leave blank to use system PATH)
FFMPEG_PATH=

# Max file size in MB (default: 500)
MAX_FILE_SIZE_MB=500

# Optional: Set to "true" to enable verbose yt-dlp output
YTDLP_VERBOSE=false
